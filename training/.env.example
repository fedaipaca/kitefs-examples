# Copy this file to .env and fill in your values.
# The .env file is gitignored and must never be committed.
#
# These variables configure KiteFS for the remote (AWS) target.
# Leave them unset or blank when running in local mode only.

# AWS credentials profile to use (must be configured in ~/.aws/config).
AWS_PROFILE=your-aws-profile

# KiteFS runtime target. Set to "remote" to switch to AWS.
KITEFS_RUNTIME_TARGET=remote

# AWS region where your S3 bucket and DynamoDB tables live.
KITEFS_AWS_REGION=us-east-1

# S3 bucket and prefix used for the published registry.
KITEFS_REMOTE_REGISTRY_S3_BUCKET=your-s3-bucket
KITEFS_REMOTE_REGISTRY_S3_PREFIX=kitefs

# S3 bucket and prefix used for the offline Parquet store.
KITEFS_REMOTE_OFFLINE_S3_BUCKET=your-s3-bucket
KITEFS_REMOTE_OFFLINE_S3_PREFIX=kitefs

# DynamoDB table name prefix for online feature tables.
KITEFS_REMOTE_ONLINE_DYNAMODB_TABLE_PREFIX=kitefs_
